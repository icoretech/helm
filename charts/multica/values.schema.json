{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "imagePullSecrets": { "type": "array", "items": { "type": "object" } },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "migrations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preUpgradeJob": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "backfillTaskUsageHourlyOnFailure": { "type": "boolean" },
            "hookWeight": { "type": "integer" },
            "hookDeletePolicy": { "type": "string" },
            "backoffLimit": { "type": "integer", "minimum": 0 },
            "ttlSecondsAfterFinished": { "type": ["integer", "null"], "minimum": 0 },
            "podAnnotations": { "type": "object" },
            "resources": { "type": "object" }
          }
        }
      }
    },
    "usageRollups": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cronJob": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "schedule": { "type": "string", "minLength": 1 },
            "concurrencyPolicy": { "type": "string", "enum": ["Allow", "Forbid", "Replace"] },
            "startingDeadlineSeconds": { "type": ["integer", "null"], "minimum": 0 },
            "successfulJobsHistoryLimit": { "type": "integer", "minimum": 0 },
            "failedJobsHistoryLimit": { "type": "integer", "minimum": 0 },
            "backoffLimit": { "type": "integer", "minimum": 0 },
            "image": { "$ref": "#/definitions/imageWithRequiredTag" },
            "podAnnotations": { "type": "object" },
            "resources": { "type": "object" }
          }
        }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "image": { "$ref": "#/definitions/image" },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" },
        "deployment": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "progressDeadlineSeconds": { "type": "integer", "minimum": 1 },
            "strategy": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "type": { "type": "string", "enum": ["Recreate", "RollingUpdate"] }
              }
            }
          }
        },
        "service": { "$ref": "#/definitions/service" },
        "config": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "appEnv": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "frontendOrigin": { "type": "string" },
            "publicUrl": { "type": "string" },
            "corsAllowedOrigins": { "type": "string" },
            "allowedOrigins": { "type": "string" },
            "metricsAddr": { "type": "string" },
            "realtimeMetricsToken": { "type": "string" },
            "realtimeMetricsTokenRef": { "$ref": "#/definitions/secretRef" },
            "authTokenTtl": { "type": "string" },
            "trustedProxies": { "type": "string" },
            "jwtSecret": { "type": "string" },
            "jwtSecretRef": { "$ref": "#/definitions/secretRef" },
            "devVerificationCode": { "type": "string" },
            "allowSignup": { "type": "boolean" },
            "allowedEmails": { "type": "string" },
            "allowedEmailDomains": { "type": "string" },
            "disableWorkspaceCreation": { "type": "boolean" },
            "cookieDomain": { "type": "string" },
            "analyticsDisabled": { "type": "boolean" },
            "analyticsEnvironment": { "type": "string" },
            "posthogApiKey": { "type": "string" },
            "posthogHost": { "type": "string" }
          }
        },
        "email": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "resendApiKey": { "type": "string" },
            "resendApiKeyRef": { "$ref": "#/definitions/secretRef" },
            "resendFromEmail": { "type": "string" },
            "smtp": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "host": { "type": "string" },
                "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
                "username": { "type": "string" },
                "usernameRef": { "$ref": "#/definitions/secretRef" },
                "password": { "type": "string" },
                "passwordRef": { "$ref": "#/definitions/secretRef" },
                "tls": { "type": "string", "enum": ["", "starttls", "implicit", "smtps", "ssl"] },
                "tlsInsecure": { "type": "boolean" },
                "ehloName": { "type": "string" }
              }
            }
          }
        },
        "google": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "clientId": { "type": "string" },
            "clientIdRef": { "$ref": "#/definitions/secretRef" },
            "clientSecret": { "type": "string" },
            "clientSecretRef": { "$ref": "#/definitions/secretRef" },
            "redirectUri": { "type": "string" }
          }
        },
        "github": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "appSlug": { "type": "string" },
            "webhookSecret": { "type": "string" },
            "webhookSecretRef": { "$ref": "#/definitions/secretRef" },
            "appId": { "type": "string" },
            "appPrivateKey": { "type": "string" },
            "appPrivateKeyRef": { "$ref": "#/definitions/secretRef" }
          },
          "allOf": [
            {
              "if": {
                "allOf": [
                  {
                    "properties": {
                      "appSlug": { "minLength": 1 }
                    }
                  },
                  {
                    "not": {
                      "anyOf": [
                        {
                          "properties": {
                            "webhookSecret": { "minLength": 1 }
                          },
                          "required": ["webhookSecret"]
                        },
                        {
                          "properties": {
                            "webhookSecretRef": {
                              "type": "object",
                              "properties": {
                                "name": { "minLength": 1 }
                              },
                              "required": ["name"]
                            }
                          },
                          "required": ["webhookSecretRef"]
                        }
                      ]
                    }
                  }
                ]
              },
              "then": {
                "required": ["backend.github.webhookSecret or backend.github.webhookSecretRef is required when backend.github.appSlug is set"]
              }
            },
            {
              "if": {
                "allOf": [
                  {
                    "anyOf": [
                      {
                        "properties": {
                          "webhookSecret": { "minLength": 1 }
                        },
                        "required": ["webhookSecret"]
                      },
                      {
                        "properties": {
                          "webhookSecretRef": {
                            "type": "object",
                            "properties": {
                              "name": { "minLength": 1 }
                            },
                            "required": ["name"]
                          }
                        },
                        "required": ["webhookSecretRef"]
                      }
                    ]
                  },
                  {
                    "not": {
                      "properties": {
                        "appSlug": { "minLength": 1 }
                      }
                    }
                  }
                ]
              },
              "then": {
                "required": ["backend.github.appSlug is required when backend.github.webhookSecret or backend.github.webhookSecretRef.name is set"]
              }
            },
            {
              "if": {
                "allOf": [
                  {
                    "properties": {
                      "webhookSecretRef": {
                        "type": "object",
                        "properties": {
                          "name": { "minLength": 1 }
                        },
                        "required": ["name"]
                      }
                    }
                  },
                  {
                    "not": {
                      "properties": {
                        "webhookSecretRef": {
                          "type": "object",
                          "properties": {
                            "key": { "minLength": 1 }
                          }
                        }
                      }
                    }
                  }
                ]
              },
              "then": {
                "required": ["backend.github.webhookSecretRef.key is required when backend.github.webhookSecretRef.name is set"]
              }
            },
            {
              "if": {
                "allOf": [
                  {
                    "properties": {
                      "appId": { "minLength": 1 }
                    }
                  },
                  {
                    "not": {
                      "anyOf": [
                        {
                          "properties": {
                            "appPrivateKey": { "minLength": 1 }
                          },
                          "required": ["appPrivateKey"]
                        },
                        {
                          "properties": {
                            "appPrivateKeyRef": {
                              "type": "object",
                              "properties": {
                                "name": { "minLength": 1 }
                              },
                              "required": ["name"]
                            }
                          },
                          "required": ["appPrivateKeyRef"]
                        }
                      ]
                    }
                  }
                ]
              },
              "then": {
                "required": ["backend.github.appPrivateKey or backend.github.appPrivateKeyRef.name is required when backend.github.appId is set"]
              }
            },
            {
              "if": {
                "allOf": [
                  {
                    "anyOf": [
                      {
                        "properties": {
                          "appPrivateKey": { "minLength": 1 }
                        },
                        "required": ["appPrivateKey"]
                      },
                      {
                        "properties": {
                          "appPrivateKeyRef": {
                            "type": "object",
                            "properties": {
                              "name": { "minLength": 1 }
                            },
                            "required": ["name"]
                          }
                        },
                        "required": ["appPrivateKeyRef"]
                      }
                    ]
                  },
                  {
                    "not": {
                      "properties": {
                        "appId": { "minLength": 1 }
                      }
                    }
                  }
                ]
              },
              "then": {
                "required": ["backend.github.appId is required when backend.github.appPrivateKey or backend.github.appPrivateKeyRef.name is set"]
              }
            },
            {
              "if": {
                "allOf": [
                  {
                    "properties": {
                      "appPrivateKeyRef": {
                        "type": "object",
                        "properties": {
                          "name": { "minLength": 1 }
                        },
                        "required": ["name"]
                      }
                    }
                  },
                  {
                    "not": {
                      "properties": {
                        "appPrivateKeyRef": {
                          "type": "object",
                          "properties": {
                            "key": { "minLength": 1 }
                          }
                        }
                      }
                    }
                  }
                ]
              },
              "then": {
                "required": ["backend.github.appPrivateKeyRef.key is required when backend.github.appPrivateKeyRef.name is set"]
              }
            }
          ]
        },
        "rateLimits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "auth": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "maxPerMinute": { "type": ["integer", "null"], "minimum": 1 },
                "verifyMaxPerMinute": { "type": ["integer", "null"], "minimum": 1 },
                "trustedProxies": { "type": "string" }
              }
            }
          }
        },
        "lark": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "secretKey": { "type": "string" },
            "secretKeyRef": { "$ref": "#/definitions/secretRef" },
            "httpBaseUrl": { "type": "string" },
            "callbackBaseUrl": { "type": "string" },
            "registrationDomain": { "type": "string" },
            "registrationLarkDomain": { "type": "string" }
          }
        },
        "usageRollups": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dailyEnabled": { "type": "boolean" },
            "dashboardEnabled": { "type": "boolean" }
          }
        },
        "extraEnv": { "$ref": "#/definitions/envList" },
        "envFrom": { "type": "array", "items": { "type": "object" } },
        "volumes": { "type": "array", "items": { "type": "object" } },
        "volumeMounts": { "type": "array", "items": { "type": "object" } },
        "resources": { "type": "object" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array", "items": { "type": "object" } },
        "affinity": { "type": "object" },
        "autoscaling": { "$ref": "#/definitions/autoscaling" }
      }
    },
    "frontend": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "image": { "$ref": "#/definitions/image" },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" },
        "service": { "$ref": "#/definitions/publicService" },
        "backendServiceAlias": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "name": { "type": "string", "minLength": 1 },
            "annotations": { "type": "object" }
          }
        },
        "extraEnv": { "$ref": "#/definitions/envList" },
        "envFrom": { "type": "array", "items": { "type": "object" } },
        "resources": { "type": "object" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array", "items": { "type": "object" } },
        "affinity": { "type": "object" },
        "autoscaling": { "$ref": "#/definitions/autoscaling" }
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pool": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxConns": { "type": ["integer", "null"], "minimum": 1 },
            "minConns": { "type": ["integer", "null"], "minimum": 1 }
          }
        },
        "internal": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "serviceName": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        },
        "external": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "url": { "type": "string" },
            "urlFrom": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "secretKeyRef": { "$ref": "#/definitions/secretRef" }
              }
            },
            "host": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "name": { "type": "string" },
            "username": { "type": "string" },
            "password": { "type": "string" },
            "sslMode": { "type": "string" }
          }
        },
        "waitForReady": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "image": { "type": "string" },
            "imagePullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
            "timeoutSeconds": { "type": "integer", "minimum": 1 },
            "periodSeconds": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "realtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "redisUrl": { "type": "string" },
        "redisUrlRef": { "$ref": "#/definitions/secretRef" }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "attachments": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "downloadMode": { "type": "string", "enum": ["auto", "cloudfront", "presign", "proxy"] },
            "downloadUrlTtl": { "type": "string" }
          }
        },
        "local": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "uploadDir": { "type": "string", "minLength": 1 },
            "baseUrl": { "type": "string" },
            "persistence": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "existingClaim": { "type": "string" },
                "storageClass": { "type": "string" },
                "annotations": { "type": "object" },
                "accessModes": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
                "size": { "type": "string" }
              }
            }
          }
        },
        "s3": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "bucket": { "type": "string" },
            "region": { "type": "string" },
            "endpointUrl": { "type": "string" },
            "accessKeyId": { "type": "string" },
            "accessKeyIdRef": { "$ref": "#/definitions/secretRef" },
            "secretAccessKey": { "type": "string" },
            "secretAccessKeyRef": { "$ref": "#/definitions/secretRef" },
            "cloudfrontDomain": { "type": "string" },
            "cloudfrontKeyPairId": { "type": "string" },
            "cloudfrontPrivateKey": { "type": "string" },
            "cloudfrontPrivateKeyRef": { "$ref": "#/definitions/secretRef" },
            "cloudfrontPrivateKeySecret": { "type": "string" }
          }
        }
      }
    },
    "ingress": { "$ref": "#/definitions/ingress" },
    "httpRoute": { "$ref": "#/definitions/httpRoute" },
    "startupProbe": { "type": "object" },
    "livenessProbe": { "type": "object" },
    "readinessProbe": { "type": "object" },
    "monitoring": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prometheusRule": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "additionalLabels": { "type": "object" },
            "samplerQueryErrorsFor": { "type": "string", "minLength": 1 },
            "samplerQueryLatencyFor": { "type": "string", "minLength": 1 },
            "severity": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        }
      }
    },
    "postgres": { "type": "object" },
    "redis": { "type": "object" }
  },
  "definitions": {
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "tag": { "type": "string" }
      }
    },
    "imageWithRequiredTag": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "tag": { "type": "string", "minLength": 1 }
      }
    },
    "secretRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "key": { "type": "string" }
      }
    },
    "envList": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "value": { "type": ["string", "number", "boolean"] },
          "valueFrom": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "annotations": { "type": "object" },
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "targetPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "nodePort": { "type": ["integer", "null"], "minimum": 30000, "maximum": 32767 }
      }
    },
    "publicService": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "annotations": { "type": "object" },
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "targetPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "nodePort": { "type": ["integer", "null"], "minimum": 30000, "maximum": 32767 },
        "loadBalancerIP": { "type": ["string", "null"] },
        "loadBalancerSourceRanges": { "type": "array", "items": { "type": "string" } },
        "externalTrafficPolicy": { "type": ["string", "null"], "enum": ["Cluster", "Local", null] }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": ["integer", "null"], "minimum": 1, "maximum": 100 },
        "targetMemoryUtilizationPercentage": { "type": ["integer", "null"], "minimum": 1, "maximum": 100 }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "backendPaths": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "paths": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["path"],
                "properties": {
                  "path": { "type": "string", "minLength": 1 },
                  "pathType": { "type": "string", "enum": ["Exact", "Prefix", "ImplementationSpecific"] }
                }
              }
            }
          }
        },
        "hosts": { "type": "array", "items": { "type": "object" } },
        "tls": { "type": "array", "items": { "type": "object" } }
      }
    },
    "httpRoute": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "annotations": { "type": "object" },
        "parentRefs": { "type": "array", "items": { "type": "object" } },
        "hostnames": { "type": "array", "items": { "type": "string" } },
        "backendMatches": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "matches": { "type": "array", "items": { "type": "object" } }
          }
        },
        "matches": { "type": "array", "items": { "type": "object" } }
      }
    }
  }
}
