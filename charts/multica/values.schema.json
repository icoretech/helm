{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "imagePullSecrets": { "type": "array", "items": { "type": "object" } },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "image": { "$ref": "#/definitions/image" },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" },
        "deployment": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "progressDeadlineSeconds": { "type": "integer", "minimum": 1 },
            "strategy": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "type": { "type": "string", "enum": ["Recreate", "RollingUpdate"] }
              }
            }
          }
        },
        "service": { "$ref": "#/definitions/service" },
        "config": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "appEnv": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "frontendOrigin": { "type": "string" },
            "corsAllowedOrigins": { "type": "string" },
            "allowedOrigins": { "type": "string" },
            "metricsAddr": { "type": "string" },
            "realtimeMetricsToken": { "type": "string" },
            "realtimeMetricsTokenRef": { "$ref": "#/definitions/secretRef" },
            "jwtSecret": { "type": "string" },
            "jwtSecretRef": { "$ref": "#/definitions/secretRef" },
            "devVerificationCode": { "type": "string" },
            "allowSignup": { "type": "boolean" },
            "allowedEmails": { "type": "string" },
            "allowedEmailDomains": { "type": "string" },
            "cookieDomain": { "type": "string" },
            "analyticsDisabled": { "type": "boolean" },
            "posthogApiKey": { "type": "string" },
            "posthogHost": { "type": "string" }
          }
        },
        "email": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "resendApiKey": { "type": "string" },
            "resendApiKeyRef": { "$ref": "#/definitions/secretRef" },
            "resendFromEmail": { "type": "string" }
          }
        },
        "google": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "clientId": { "type": "string" },
            "clientIdRef": { "$ref": "#/definitions/secretRef" },
            "clientSecret": { "type": "string" },
            "clientSecretRef": { "$ref": "#/definitions/secretRef" },
            "redirectUri": { "type": "string" }
          }
        },
        "extraEnv": { "$ref": "#/definitions/envList" },
        "envFrom": { "type": "array", "items": { "type": "object" } },
        "volumes": { "type": "array", "items": { "type": "object" } },
        "volumeMounts": { "type": "array", "items": { "type": "object" } },
        "resources": { "type": "object" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array", "items": { "type": "object" } },
        "affinity": { "type": "object" },
        "autoscaling": { "$ref": "#/definitions/autoscaling" }
      }
    },
    "frontend": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "image": { "$ref": "#/definitions/image" },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" },
        "service": { "$ref": "#/definitions/publicService" },
        "backendServiceAlias": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "name": { "type": "string", "minLength": 1 },
            "annotations": { "type": "object" }
          }
        },
        "extraEnv": { "$ref": "#/definitions/envList" },
        "envFrom": { "type": "array", "items": { "type": "object" } },
        "resources": { "type": "object" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array", "items": { "type": "object" } },
        "affinity": { "type": "object" },
        "autoscaling": { "$ref": "#/definitions/autoscaling" }
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pool": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxConns": { "type": ["integer", "null"], "minimum": 1 },
            "minConns": { "type": ["integer", "null"], "minimum": 1 }
          }
        },
        "internal": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "serviceName": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        },
        "external": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "url": { "type": "string" },
            "urlFrom": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "secretKeyRef": { "$ref": "#/definitions/secretRef" }
              }
            },
            "host": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "name": { "type": "string" },
            "username": { "type": "string" },
            "password": { "type": "string" },
            "sslMode": { "type": "string" }
          }
        },
        "waitForReady": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "image": { "type": "string" },
            "imagePullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
            "timeoutSeconds": { "type": "integer", "minimum": 1 },
            "periodSeconds": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "realtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "redisUrl": { "type": "string" },
        "redisUrlRef": { "$ref": "#/definitions/secretRef" }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "local": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "uploadDir": { "type": "string", "minLength": 1 },
            "baseUrl": { "type": "string" },
            "persistence": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "existingClaim": { "type": "string" },
                "storageClass": { "type": "string" },
                "annotations": { "type": "object" },
                "accessModes": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
                "size": { "type": "string" }
              }
            }
          }
        },
        "s3": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "bucket": { "type": "string" },
            "region": { "type": "string" },
            "endpointUrl": { "type": "string" },
            "accessKeyId": { "type": "string" },
            "accessKeyIdRef": { "$ref": "#/definitions/secretRef" },
            "secretAccessKey": { "type": "string" },
            "secretAccessKeyRef": { "$ref": "#/definitions/secretRef" },
            "cloudfrontDomain": { "type": "string" },
            "cloudfrontKeyPairId": { "type": "string" },
            "cloudfrontPrivateKey": { "type": "string" },
            "cloudfrontPrivateKeyRef": { "$ref": "#/definitions/secretRef" },
            "cloudfrontPrivateKeySecret": { "type": "string" }
          }
        }
      }
    },
    "ingress": { "$ref": "#/definitions/ingress" },
    "httpRoute": { "$ref": "#/definitions/httpRoute" },
    "livenessProbe": { "type": "object" },
    "readinessProbe": { "type": "object" },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        }
      }
    },
    "postgres": { "type": "object" },
    "redis": { "type": "object" }
  },
  "definitions": {
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "tag": { "type": "string" }
      }
    },
    "secretRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "key": { "type": "string" }
      }
    },
    "envList": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "value": { "type": ["string", "number", "boolean"] },
          "valueFrom": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "annotations": { "type": "object" },
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "targetPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "nodePort": { "type": ["integer", "null"], "minimum": 30000, "maximum": 32767 }
      }
    },
    "publicService": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "annotations": { "type": "object" },
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "targetPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "nodePort": { "type": ["integer", "null"], "minimum": 30000, "maximum": 32767 },
        "loadBalancerIP": { "type": ["string", "null"] },
        "loadBalancerSourceRanges": { "type": "array", "items": { "type": "string" } },
        "externalTrafficPolicy": { "type": ["string", "null"], "enum": ["Cluster", "Local", null] }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": ["integer", "null"], "minimum": 1, "maximum": 100 },
        "targetMemoryUtilizationPercentage": { "type": ["integer", "null"], "minimum": 1, "maximum": 100 }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "backendPaths": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "paths": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["path"],
                "properties": {
                  "path": { "type": "string", "minLength": 1 },
                  "pathType": { "type": "string", "enum": ["Exact", "Prefix", "ImplementationSpecific"] }
                }
              }
            }
          }
        },
        "hosts": { "type": "array", "items": { "type": "object" } },
        "tls": { "type": "array", "items": { "type": "object" } }
      }
    },
    "httpRoute": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "annotations": { "type": "object" },
        "parentRefs": { "type": "array", "items": { "type": "object" } },
        "hostnames": { "type": "array", "items": { "type": "string" } },
        "backendMatches": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "matches": { "type": "array", "items": { "type": "object" } }
          }
        },
        "matches": { "type": "array", "items": { "type": "object" } }
      }
    }
  }
}
