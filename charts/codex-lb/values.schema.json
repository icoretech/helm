{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "replicaCount": { "type": "integer", "minimum": 1 },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "tag": { "type": "string" }
      },
      "required": ["repository", "pullPolicy"]
    },
    "imagePullSecrets": { "type": "array", "items": { "type": "object" } },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "podAnnotations": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean"] }
    },
    "podLabels": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean"] }
    },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "annotations": { "type": "object" },
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "targetPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "nodePort": { "type": ["integer", "null"], "minimum": 30000, "maximum": 32767 },
        "loadBalancerIP": { "type": ["string", "null"] },
        "loadBalancerSourceRanges": { "type": "array", "items": { "type": "string" } },
        "externalTrafficPolicy": { "type": ["string", "null"], "enum": ["Cluster", "Local", null] },
        "oauth": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "nodePort": { "type": ["integer", "null"], "minimum": 30000, "maximum": 32767 }
          }
        }
      },
      "required": ["type", "port", "targetPort"]
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "host": { "type": "string", "minLength": 1 },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "path": { "type": "string", "minLength": 1 },
                    "pathType": { "type": "string", "enum": ["ImplementationSpecific", "Exact", "Prefix"] }
                  },
                  "required": ["path"]
                }
              }
            },
            "required": ["host", "paths"]
          }
        },
        "tls": { "type": "array", "items": { "type": "object" } },
        "oauth": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "className": { "type": "string" },
            "annotations": { "type": "object" },
            "hosts": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "host": { "type": "string", "minLength": 1 },
                  "paths": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "path": { "type": "string", "minLength": 1 },
                        "pathType": { "type": "string", "enum": ["ImplementationSpecific", "Exact", "Prefix"] }
                      },
                      "required": ["path"]
                    }
                  }
                },
                "required": ["host", "paths"]
              }
            },
            "tls": { "type": "array", "items": { "type": "object" } }
          }
        }
      },
      "required": ["enabled"]
    },
    "httpRoute": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "annotations": { "type": "object" },
        "parentRefs": { "type": "array", "items": { "type": "object" } },
        "hostnames": { "type": "array", "items": { "type": "string" } },
        "matches": { "type": "array", "minItems": 1, "items": { "type": "object" } },
        "oauth": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "parentRefs": { "type": "array", "items": { "type": "object" } },
            "hostnames": { "type": "array", "items": { "type": "string" } },
            "matches": { "type": "array", "minItems": 1, "items": { "type": "object" } }
          }
        }
      },
      "required": ["enabled", "parentRefs", "matches"]
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "progressDeadlineSeconds": { "type": "integer", "minimum": 1 },
        "strategy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["Recreate", "RollingUpdate"] }
          },
          "required": ["type"]
        }
      },
      "required": ["progressDeadlineSeconds", "strategy"]
    },
    "resources": { "type": "object" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array", "items": { "type": "object" } },
    "affinity": { "type": "object" },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "existingClaim": { "type": "string" },
        "storageClass": { "type": "string" },
        "annotations": { "type": "object" },
        "accessModes": { "type": "array", "items": { "type": "string" } },
        "size": { "type": "string", "minLength": 1 },
        "volumeMode": { "type": "string" },
        "mountPath": { "type": "string", "minLength": 1 }
      },
      "required": ["enabled", "accessModes", "size", "mountPath"]
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "databaseUrl": { "type": "string" },
        "databasePoolSize": { "type": "integer", "minimum": 1 },
        "databaseMigrateOnStartup": { "type": "boolean" },
        "upstreamBaseUrl": { "type": "string" },
        "upstreamStreamTransport": { "type": "string", "enum": ["auto", "http", "websocket"] },
        "proxyRequestBudgetSeconds": { "type": "integer", "minimum": 1 },
        "streamIdleTimeoutSeconds": { "type": "integer", "minimum": 1 },
        "authBaseUrl": { "type": "string" },
        "oauthCallbackHost": { "type": "string" },
        "oauthCallbackPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "oauthRedirectUri": { "type": "string" },
        "firewallTrustProxyHeaders": { "type": "boolean" },
        "firewallTrustedProxyCidrs": { "type": "string" },
        "modelRegistryEnabled": { "type": "boolean" },
        "imageInlineFetchEnabled": { "type": "boolean" },
        "sessionBridgeInstanceId": { "type": "string" },
        "sessionBridgeInstanceRing": { "type": "string" }
      }
    },
    "encryptionKey": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "existingSecret": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "key": { "type": "string" }
          }
        }
      }
    },
    "extraEnv": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "value": { "type": ["string", "number", "boolean"] },
          "valueFrom": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "envFrom": { "type": "array", "items": { "type": "object" } },
    "volumes": { "type": "array", "items": { "type": "object" } },
    "volumeMounts": { "type": "array", "items": { "type": "object" } },
    "livenessProbe": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "httpGet": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "path": { "type": "string", "minLength": 1 }
          },
          "required": ["path"]
        },
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "successThreshold": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 }
      },
      "required": ["enabled", "httpGet"]
    },
    "readinessProbe": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "httpGet": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "path": { "type": "string", "minLength": 1 }
          },
          "required": ["path"]
        },
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "successThreshold": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 }
      },
      "required": ["enabled", "httpGet"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "httpRoute": {
            "type": "object",
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "httpRoute": {
            "type": "object",
            "properties": { "parentRefs": { "minItems": 1 } }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "httpRoute": {
            "type": "object",
            "properties": {
              "oauth": {
                "type": "object",
                "properties": { "enabled": { "const": true } },
                "required": ["enabled"]
              }
            },
            "required": ["oauth"]
          }
        }
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "httpRoute": {
                "type": "object",
                "properties": { "parentRefs": { "minItems": 1 } }
              }
            }
          },
          {
            "properties": {
              "httpRoute": {
                "type": "object",
                "properties": {
                  "oauth": {
                    "type": "object",
                    "properties": { "parentRefs": { "minItems": 1 } }
                  }
                }
              }
            }
          }
        ]
      }
    }
  ]
}
