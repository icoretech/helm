{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies", "renovate"],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "branchConcurrentLimit": 0,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^charts\\/airbroke\\/Chart\\.yaml$/"],
      "matchStrings": ["appVersion:\\s*\\\"?(?<currentValue>[^\\\"\\s]+)\\\"?"],
      "depNameTemplate": "icoretech/airbroke",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^charts\\/airbroke\\/Chart\\.yaml$/"],
      "matchStrings": ["image:\\s*ghcr\\.io\\/icoretech\\/airbroke:(?<currentValue>[^\\s]+)"],
      "depNameTemplate": "icoretech/airbroke",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^charts\\/browserless\\/Chart\\.yaml$/"],
      "matchStrings": ["appVersion:\\s*\\\"?(?<currentValue>[^\\\"\\s]+)\\\"?"],
      "depNameTemplate": "browserless/browserless",
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^charts\\/browserless\\/Chart\\.yaml$/"],
      "matchStrings": ["image:\\s*ghcr\\.io\\/browserless\\/chromium:(?<currentValue>[^\\s]+)"],
      "depNameTemplate": "browserless/browserless",
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^charts\\/metamcp\\/Chart\\.yaml$/"],
      "matchStrings": ["appVersion:\\s*\\\"?(?<currentValue>[^\\\"\\s]+)\\\"?"],
      "depNameTemplate": "metatool-ai/metamcp",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^charts\\/metamcp\\/Chart\\.yaml$/"],
      "matchStrings": ["image:\\s*ghcr\\.io\\/metatool-ai\\/metamcp:(?<currentValue>[^\\s]+)"],
      "depNameTemplate": "metatool-ai/metamcp",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^charts\\/tolgee\\/Chart\\.yaml$/"],
      "matchStrings": ["appVersion:\\s*\\\"?(?<currentValue>[^\\\"\\s]+)\\\"?"],
      "depNameTemplate": "tolgee/tolgee",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^charts\\/tolgee\\/Chart\\.yaml$/"],
      "matchStrings": ["image:\\s*tolgee\\/tolgee:(?<currentValue>[^\\s]+)"],
      "depNameTemplate": "tolgee/tolgee",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^charts\\/pgbouncer\\/Chart\\.yaml$/"],
      "matchStrings": ["appVersion:\\s*\\\"?(?<currentValue>[^\\\"\\s]+)\\\"?"],
      "depNameTemplate": "ghcr.io/icoretech/pgbouncer-docker",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^charts\\/pgbouncer\\/Chart\\.yaml$/"],
      "matchStrings": ["image:\\s*ghcr\\.io\\/icoretech\\/pgbouncer-docker:(?<currentValue>[^\\s]+)"],
      "depNameTemplate": "ghcr.io/icoretech/pgbouncer-docker",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^charts\\/codex-lb\\/Chart\\.yaml$/"],
      "matchStrings": ["appVersion:\\s*\\\"?(?<currentValue>[^\\\"\\s]+)\\\"?"],
      "depNameTemplate": "Soju06/codex-lb",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^charts\\/codex-lb\\/Chart\\.yaml$/"],
      "matchStrings": ["image:\\s*ghcr\\.io\\/soju06\\/codex-lb:(?<currentValue>[^\\s]+)"],
      "depNameTemplate": "Soju06/codex-lb",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["custom.regex", "helm-values", "helmv3"],
      "matchFileNames": ["charts/**"],
      "automerge": false
    },
    {
      "matchManagers": ["custom.regex", "helm-values", "helmv3"],
      "matchFileNames": ["charts/**"],
      "prConcurrentLimit": 0,
      "branchConcurrentLimit": 0,
      "recreateWhen": "always"
    },
    {
      "matchManagers": ["helmv3"],
      "matchFileNames": ["charts/**"],
      "enabled": false
    },
    {
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["charts/**"],
      "bumpVersions": [
        {
          "name": "Bump chart version",
          "filePatterns": ["{{packageFileDir}}/Chart.yaml"],
          "matchStrings": ["version:\\s*\\\"?(?<version>\\d+\\.\\d+\\.\\d+)\\\"?"],
          "bumpType": "{{#if isPatch}}patch{{else if isMinor}}minor{{else if isMajor}}major{{else}}minor{{/if}}"
        }
      ]
    },
    {
      "matchManagers": ["helm-values", "helmv3"],
      "matchFileNames": ["charts/**"],
      "bumpVersions": [
        {
          "name": "Bump chart version",
          "filePatterns": ["{{packageFileDir}}/Chart.yaml"],
          "matchStrings": ["version:\\s*\\\"?(?<version>\\d+\\.\\d+\\.\\d+)\\\"?"],
          "bumpType": "{{#if isMajor}}major{{else}}patch{{/if}}"
        }
      ]
    },
    {
      "matchManagers": ["helm-values"],
      "matchDatasources": ["docker"],
      "matchFileNames": ["charts/metamcp/**"],
      "matchPackageNames": ["postgres"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["icoretech/airbroke"],
      "groupName": "airbroke chart software updates"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["icoretech/airbroke"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["browserless/browserless"],
      "groupName": "browserless chart software updates"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["browserless/browserless"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["metatool-ai/metamcp"],
      "groupName": "metamcp chart software updates"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["tolgee/tolgee"],
      "groupName": "tolgee chart software updates"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["tolgee/tolgee"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchManagers": ["custom.regex", "helm-values"],
      "matchPackageNames": ["ghcr.io/icoretech/pgbouncer-docker"],
      "groupName": "pgbouncer chart software updates"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["Soju06/codex-lb"],
      "groupName": "codex-lb chart software updates"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["Soju06/codex-lb"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchPackageNames": ["inngest/inngest"],
      "enabled": false
    }
  ]
}
